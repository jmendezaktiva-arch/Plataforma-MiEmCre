rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- SENTINEL: Normalización de roles (Resiliente) ---
    // Objetivo: evitar bloqueos por variantes como "Admin", "admin" o "Administrador".
    function getRoleNormalized() {
      return request.auth == null
        ? ''
        : (
            exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
              ? (
                  get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol is string
                    ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol.lower()
                    : ''
                )
              : ''
          );
    }

    function isAdmin() {
      // Acepta espacios accidentales alrededor del rol.
      return getRoleNormalized().matches('^\\s*admin(istrador)?\\s*$');
    }

    // --- COLECCIÓN DE USUARIOS Y PROGRESO ---
    match /usuarios/{userId} {
      // LECTURA: Prioridad al dueño para evitar recursividad en getRole()
      allow read: if request.auth != null && (
        request.auth.uid == userId || 
        (request.auth.uid != userId && isAdmin())
      );
      
      // Gestión de perfiles: El dueño puede actualizar su propia info básica; Admin total.
      allow write: if request.auth != null && (
        request.auth.uid == userId || 
        (request.auth.uid != userId && isAdmin())
      );

      // SUB-COLECCIÓN QUIRÚRGICA: Habilita el guardado de Workbooks y Academia
      // El usuario puede leer y escribir su propio avance. Admin y Consultores pueden supervisar.
      match /progreso_workbooks/{sessionId} {
        allow read: if request.auth != null && (
          request.auth.uid == userId || 
          getRoleNormalized() in ['admin', 'administrador', 'consultor', 'capacitador']
        );
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- COLECCIÓN DE RESPUESTAS (Libro de Trabajo) ---
    match /respuestas/{documentId} {
      
      // Lectura: Clientes leen lo suyo; Admin, Consultor y Capacitador leen todo.
      allow read: if request.auth != null && (
        resource.data.usuarioId == request.auth.uid || 
        getRoleNormalized() in ['admin', 'administrador', 'consultor', 'capacitador']
      );

      // Escritura de Respuestas: 
      // El Cliente crea/edita su avance. El Admin tiene control total.
      // El Consultor NO puede modificar la respuesta del cliente aquí.
      allow write: if request.auth != null && (
        (request.resource.data.usuarioId == request.auth.uid) || 
        isAdmin()
      );

      // --- SUB-COLECCIÓN DE FEEDBACK (Nueva) ---
      // Aquí es donde el Consultor deja sus comentarios.
      match /feedback/{feedbackId} {
        
        // Lectura: El Cliente puede leer el feedback que le dejaron. 
        // Admin, Consultor y Capacitador también pueden leerlo.
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/respuestas/$(documentId)).data.usuarioId == request.auth.uid ||
          getRoleNormalized() in ['admin', 'administrador', 'consultor', 'capacitador']
        );

        // Escritura de Feedback: 
        // Solo el Consultor y el Admin pueden escribir o editar comentarios.
        allow create, update: if request.auth != null && (
          getRoleNormalized() in ['admin', 'administrador', 'consultor']
        );
        
        // Borrado: Solo el Admin puede borrar comentarios permanentemente.
        allow delete: if request.auth != null && isAdmin();
      }
    }

    // --- COLECCIÓN DE CATÁLOGO (Academia) ---
    match /config_ecosistema/{documentId} {
      // Cualquier usuario autenticado puede leer el catálogo de cursos
      allow read: if request.auth != null;
      
      // Solo el Admin puede modificar el catálogo (precio, títulos, orden)
      allow write: if request.auth != null && isAdmin();
    }

    // --- COLECCIÓN DE CONSULTORÍA (Servicios y Precios) --- [cite: 212, 213]
    match /config_consultoria/{documentId} {
      // Cualquier usuario autenticado puede leer el catálogo de servicios 
      allow read: if request.auth != null;
      // Solo el Admin Jorge puede modificar servicios, precios o destacar la IA [cite: 29, 85]
      allow write: if request.auth != null && isAdmin();
    }

    // --- COLECCIÓN DE SOPORTE (Formulario de Contacto) --- [cite: 94, 102]
    match /solicitudes_contacto/{solicitudId} {
      // Los usuarios pueden crear solicitudes; el Admin puede leerlas todas
      allow create: if request.auth != null;
      allow read, write: if request.auth != null && isAdmin();
    }

    // --- COLECCIÓN DE CONFIGURACIÓN DE APPS (Catálogo SaaS) ---
    match /config_apps/{appId} {
      // Cualquier usuario autenticado puede leer el catálogo para renderizar su panel.
      allow read: if request.auth != null;
      // Solo el Admin Jorge puede dar de alta o modificar aplicaciones.
      allow write: if request.auth != null && isAdmin();
    }

    // --- COLECCIÓN DE EXPEDIENTES (Sentinel de Vigencia) ---
    match /expedientes/{userId} {
      // El cliente lee su propia vigencia; el Admin tiene supervisión total.
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      // Solo el Admin puede modificar fechas de vencimiento o asignar permisos.
      allow write: if request.auth != null && isAdmin();
    }

  }
}